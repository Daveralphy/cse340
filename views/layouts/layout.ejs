<!DOCTYPE html>
<html lang="en">
<%- include("../partials/head") %>
<body>
  <%- include("../partials/header") %>
  <% if (typeof nav !== "undefined") { %>
    <%- nav %>
  <% } else { %>
    <%- include("../partials/navigation") %>
  <% } %>
  
  <!-- Flash Messages -->
  <% if (messages.notice) { %>
    <div class="flash-notice">
      <%= messages.notice %>
    </div>
  <% } %>
  <% if (messages.error) { %>
    <div class="flash-error">
      <%= messages.error %>
    </div>
  <% } %>
  
  <main>
    <%- body %>
  </main>
  <%- include("../partials/footer") %>
</body>
</html>
