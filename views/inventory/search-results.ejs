<nav class="breadcrumbs breadcrumbs-with-action" aria-label="Breadcrumb">
  <div class="breadcrumb-text">
    <a href="/">Home</a> <span>/</span> <span>Search Results</span>
  </div>
  <% if (typeof loggedin !== "undefined" && loggedin) { %>
    <a href="/account/saved" class="btn-saved-nav" title="View your saved vehicles">Saved Vehicles</a>
  <% } %>
</nav>

<div class="inventory-page">
  <!-- Search/Filter Form - Always Visible -->
  <div class="search-filter-form">
    <form method="GET" action="/search" class="filter-form">
      <div class="filter-inputs">
        <div class="search-input-group">
          <label for="query">Search By Make/Model:</label>
          <input 
            type="text" 
            id="query"
            name="query" 
            placeholder="e.g., Jeep, Honda, etc." 
            value="<%= filters.keyword || '' %>"
          >
        </div>

        <div class="form-group">
          <label for="classification_id">Classification:</label>
          <%- classificationSelect %>
        </div>

        <div class="form-group">
          <label for="price_min">Min Price:</label>
          <input 
            type="number" 
            id="price_min"
            name="price_min" 
            placeholder="Min" 
            min="0" 
            step="1000"
            value="<%= filters.price_min > 0 ? filters.price_min : '' %>"
          >
        </div>

        <div class="form-group">
          <label for="price_max">Max Price:</label>
          <input 
            type="number" 
            id="price_max"
            name="price_max" 
            placeholder="Max" 
            min="0" 
            step="1000"
            value="<%= filters.price_max > 0 ? filters.price_max : '' %>"
          >
        </div>

        <div class="form-group">
          <label for="mileage_min">Min Mileage:</label>
          <input 
            type="number" 
            id="mileage_min"
            name="mileage_min" 
            placeholder="Min" 
            min="0" 
            step="1000"
            value="<%= filters.mileage_min > 0 ? filters.mileage_min : '' %>"
          >
        </div>

        <div class="form-group">
          <label for="mileage_max">Max Mileage:</label>
          <input 
            type="number" 
            id="mileage_max"
            name="mileage_max" 
            placeholder="Max" 
            min="0" 
            step="1000"
            value="<%= filters.mileage_max > 0 ? filters.mileage_max : '' %>"
          >
        </div>

        <button type="submit" class="btn-filter">Filter</button>
      </div>
    </form>
  </div>

  <!-- Vehicle Grid -->
  <%- grid %>
</div>

<script src="/js/favorites.js"></script>
