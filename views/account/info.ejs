<!DOCTYPE html>
<html lang="en">
<%- include("../partials/head") %>
<body>
  <%- include("../partials/header") %>
  <%- include("../partials/navigation") %>

<div style="max-width: 1000px; margin: 40px auto; padding: 20px;">
  
  <div style="display: flex; align-items: center; margin-bottom: 40px; padding-bottom: 20px; border-bottom: 2px solid #eee;">
    <div style="width: 80px; height: 80px; border-radius: 50%; background-color: #007bff; display: flex; align-items: center; justify-content: center; margin-right: 20px; color: white; font-size: 40px; font-weight: bold;">
      <%= accountData.account_firstname.charAt(0).toUpperCase() %>
    </div>
    <div>
      <h1 style="margin: 0; font-size: 28px;"><%= accountData.account_firstname %> <%= accountData.account_lastname %></h1>
      <p style="margin: 5px 0; color: #666; font-size: 14px;">Account Type: <strong><%= accountData.account_type %></strong></p>
    </div>
    <a href="/account/update" style="margin-left: auto; padding: 10px 20px; background-color: transparent; border: none; color: #003399; text-decoration: none; cursor: pointer; font-size: 14px; font-weight: bold;">Update Account</a>
  </div>

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
    <div style="background-color: #f9f9f9; padding: 20px; border-radius: 8px;">
      <label style="font-weight: bold; display: block; margin-bottom: 10px; color: #666; font-size: 12px; text-transform: uppercase;">First Name</label>
      <p style="margin: 0; padding: 10px 0; font-size: 16px;">
        <%= accountData.account_firstname %>
      </p>
    </div>

    <div style="background-color: #f9f9f9; padding: 20px; border-radius: 8px;">
      <label style="font-weight: bold; display: block; margin-bottom: 10px; color: #666; font-size: 12px; text-transform: uppercase;">Last Name</label>
      <p style="margin: 0; padding: 10px 0; font-size: 16px;">
        <%= accountData.account_lastname %>
      </p>
    </div>

    <div style="background-color: #f9f9f9; padding: 20px; border-radius: 8px;">
      <label style="font-weight: bold; display: block; margin-bottom: 10px; color: #666; font-size: 12px; text-transform: uppercase;">Username</label>
      <p style="margin: 0; padding: 10px 0; font-size: 16px;">
        <%= accountData.account_username %>
      </p>
    </div>

    <div style="background-color: #f9f9f9; padding: 20px; border-radius: 8px;">
      <label style="font-weight: bold; display: block; margin-bottom: 10px; color: #666; font-size: 12px; text-transform: uppercase;">Email</label>
      <p style="margin: 0; padding: 10px 0; font-size: 16px;">
        <%= accountData.account_email %>
      </p>
    </div>
  </div>

</div>

  <%- include("../partials/footer") %>
</body>
</html>
