<%- include("../partials/header") %>

<div class="auth-container" style="max-width: 600px; margin: 40px auto; padding: 20px;">
  <h1>Update Account</h1>

  <% if (errors && errors.length > 0) { %>
    <div class="error-messages" id="errorBox" style="background-color: #f8d7da; color: #721c24; padding: 15px; border-radius: 4px; margin-bottom: 20px;">
      <% errors.forEach(error => { %>
        <p style="margin: 5px 0;"><%= error.msg %></p>
      <% }) %>
    </div>
  <% } %>

  <% if (typeof message !== "undefined" && message) { %>
    <p class="success" style="background-color: #d4edda; color: #155724; padding: 15px; border-radius: 4px; margin-bottom: 20px;"><%= message %></p>
  <% } %>

  <h2 style="margin-top: 30px; margin-bottom: 20px;">Account Information</h2>
  <form action="/account/update" method="post">
    <input type="hidden" name="account_id" value="<%= accountData.account_id %>">

    <label for="account_firstname" style="font-weight: bold; display: block; margin-top: 15px; margin-bottom: 5px;">First Name</label>
    <input 
      type="text" 
      name="account_firstname" 
      id="account_firstname" 
      value="<%= accountData.account_firstname %>"
      required
      style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px; box-sizing: border-box;"
    >

    <label for="account_lastname" style="font-weight: bold; display: block; margin-top: 15px; margin-bottom: 5px;">Last Name</label>
    <input 
      type="text" 
      name="account_lastname" 
      id="account_lastname" 
      value="<%= accountData.account_lastname %>"
      required
      style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px; box-sizing: border-box;"
    >

    <label for="account_email" style="font-weight: bold; display: block; margin-top: 15px; margin-bottom: 5px;">Email</label>
    <input 
      type="email" 
      name="account_email" 
      id="account_email" 
      value="<%= accountData.account_email %>"
      required
      style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px; box-sizing: border-box;"
    >

    <button type="submit" style="margin-top: 20px; padding: 10px 20px; background-color: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 16px;">Update Account</button>
  </form>

  <hr style="margin: 40px 0; border: none; border-top: 1px solid #ddd;">

  <h2 style="margin-bottom: 20px;">Change Password</h2>
  <form action="/account/update-password" method="post" id="passwordForm">
    <input type="hidden" name="account_id" value="<%= accountData.account_id %>">

    <label for="account_password" style="font-weight: bold; display: block; margin-top: 15px; margin-bottom: 5px;">New Password</label>
    <small style="display: block; margin-bottom: 10px; color: #666;">Password must be at least 8 characters, contain at least one number, one uppercase letter, and one special character (!@#$%^&*)</small>
    <input 
      type="password" 
      name="account_password" 
      id="account_password" 
      required
      style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px; box-sizing: border-box;"
    >

    <label for="confirm_password" style="font-weight: bold; display: block; margin-top: 15px; margin-bottom: 5px;">Confirm Password</label>
    <input 
      type="password" 
      name="confirm_password" 
      id="confirm_password" 
      required
      style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px; box-sizing: border-box;"
    >

    <button type="submit" style="margin-top: 20px; padding: 10px 20px; background-color: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 16px;">Change Password</button>
  </form>
</div>

<script>
  // Password validation on submit
  document.getElementById("passwordForm").addEventListener("submit", function(e) {
    const password = document.getElementById("account_password").value
    const confirmPassword = document.getElementById("confirm_password").value

    if (password !== confirmPassword) {
      e.preventDefault()
      alert("Passwords do not match. Please try again.")
      return
    }
  })

  // Auto-dismiss error messages
  const errorBox = document.getElementById("errorBox")
  if (errorBox) {
    setTimeout(() => {
      errorBox.style.display = "none"
    }, 5000)
  }
</script>

</div>

<%- include("../partials/footer") %>
