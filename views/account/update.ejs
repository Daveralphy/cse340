<%- include("../partials/header") %>

<div class="auth-container">
  <h1>Update Account</h1>

  <% if (errors && errors.length > 0) { %>
    <div class="errors">
      <% errors.forEach(error => { %>
        <p><%= error.msg %></p>
      <% }) %>
    </div>
  <% } %>

  <% if (typeof message !== "undefined" && message) { %>
    <p class="success"><%= message %></p>
  <% } %>

  <h2>Account Information</h2>
  <form action="/account/update" method="post">
    <input type="hidden" name="account_id" value="<%= accountData.account_id %>">

    <label for="account_firstname">First Name</label>
    <input 
      type="text" 
      name="account_firstname" 
      id="account_firstname" 
      value="<%= accountData.account_firstname %>"
      required
    >

    <label for="account_lastname">Last Name</label>
    <input 
      type="text" 
      name="account_lastname" 
      id="account_lastname" 
      value="<%= accountData.account_lastname %>"
      required
    >

    <label for="account_email">Email</label>
    <input 
      type="email" 
      name="account_email" 
      id="account_email" 
      value="<%= accountData.account_email %>"
      required
    >

    <button type="submit">Update Account</button>
  </form>

  <hr>

  <h2>Change Password</h2>
  <form action="/account/update-password" method="post">
    <input type="hidden" name="account_id" value="<%= accountData.account_id %>">

    <label for="account_password">New Password</label>
    <small>Password must be at least 8 characters, contain at least one number, one uppercase letter, and one special character (!@#$%^&*)</small>
    <input 
      type="password" 
      name="account_password" 
      id="account_password" 
      required
    >

    <button type="submit">Change Password</button>
  </form>
</div>

<%- include("../partials/footer") %>
