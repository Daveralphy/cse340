<div class="inventory-page">
  <!-- Action Buttons Header -->
  <div class="filter-header">
    <% if (typeof loggedin !== "undefined" && loggedin) { %>
      <a href="/account/saved" class="btn-saved-nav" title="View your saved vehicles">Saved Vehicles</a>
    <% } %>
    <button type="button" class="btn-filter-icon" id="filterToggle" title="Open filter">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
      </svg>
    </button>
  </div>

  <!-- Filter Modal -->
  <div class="filter-modal" id="filterModal">
    <div class="filter-modal-content">
      <button type="button" class="btn-close-modal" id="filterClose" title="Close filter">&times;</button>
      <div class="search-filter-form">
        <form method="GET" action="/search" class="filter-form">
          <div class="filter-inputs">
            <div class="search-input-group">
              <label for="query-search">Search by Make/Model:</label>
              <input 
                type="text" 
                id="query-search"
                name="query" 
                placeholder="Search by Make/Model..." 
              >
            </div>

            <div class="form-group">
              <label for="price_min">Min Price:</label>
              <input 
                type="number" 
                id="price_min"
                name="price_min" 
                placeholder="Min Price" 
                min="0" 
                step="1000"
              >
            </div>

            <div class="form-group">
              <label for="price_max">Max Price:</label>
              <input 
                type="number" 
                id="price_max"
                name="price_max" 
                placeholder="Max Price" 
                min="0" 
                step="1000"
              >
            </div>

            <div class="form-group">
              <label for="mileage_max">Max Mileage:</label>
              <input 
                type="number" 
                id="mileage_max"
                name="mileage_max" 
                placeholder="Max Mileage" 
                min="0" 
                step="1000"
              >
            </div>

            <button type="submit" class="btn-filter">Filter</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <%- grid %>
</div>

<script src="/js/favorites.js"></script>
