<div class="form-container">
  <h1>Add New Vehicle</h1>

  <form action="/inv/add-vehicle" method="post" class="form-group">
    <!-- Classification Dropdown -->
    <div class="form-field">
      <label for="classification_id">Classification:</label>
      <%- dropdown %>
      <small style="color: var(--text-light); margin-top: 0.25rem;">* Required</small>
    </div>

    <!-- Make Field -->
    <div class="form-field">
      <label for="inv_make">Make:</label>
      <input
        type="text"
        id="inv_make"
        name="inv_make"
        value="<%= typeof locals.inv_make !== 'undefined' ? locals.inv_make : '' %>"
        required
        placeholder="e.g., Honda, Toyota, Ford"
      />
    </div>

    <!-- Model Field -->
    <div class="form-field">
      <label for="inv_model">Model:</label>
      <input
        type="text"
        id="inv_model"
        name="inv_model"
        value="<%= typeof locals.inv_model !== 'undefined' ? locals.inv_model : '' %>"
        required
        placeholder="e.g., Civic, Camry, Mustang"
      />
    </div>

    <!-- Year Field -->
    <div class="form-field">
      <label for="inv_year">Year:</label>
      <input
        type="number"
        id="inv_year"
        name="inv_year"
        value="<%= typeof locals.inv_year !== 'undefined' ? locals.inv_year : '' %>"
        required
        min="1900"
        max="2100"
        placeholder="e.g., 2023"
      />
    </div>

    <!-- Description Field -->
    <div class="form-field">
      <label for="inv_description">Description:</label>
      <textarea
        id="inv_description"
        name="inv_description"
        required
        placeholder="Enter vehicle description..."
      ><%= typeof locals.inv_description !== 'undefined' ? locals.inv_description : '' %></textarea>
    </div>

    <!-- Image Path Field -->
    <div class="form-field">
      <label for="inv_image">Image Path:</label>
      <input
        type="text"
        id="inv_image"
        name="inv_image"
        value="<%= typeof locals.inv_image !== 'undefined' ? locals.inv_image : '' %>"
        required
        placeholder="e.g., /images/vehicles/image.jpg"
      />
      <small style="color: var(--text-light); margin-top: 0.25rem;">Full path to the main vehicle image</small>
    </div>

    <!-- Thumbnail Path Field -->
    <div class="form-field">
      <label for="inv_thumbnail">Thumbnail Path:</label>
      <input
        type="text"
        id="inv_thumbnail"
        name="inv_thumbnail"
        value="<%= typeof locals.inv_thumbnail !== 'undefined' ? locals.inv_thumbnail : '' %>"
        required
        placeholder="e.g., /images/vehicles/thumb.jpg"
      />
      <small style="color: var(--text-light); margin-top: 0.25rem;">Full path to the thumbnail image</small>
    </div>

    <!-- Price Field -->
    <div class="form-field">
      <label for="inv_price">Price ($):</label>
      <input
        type="number"
        id="inv_price"
        name="inv_price"
        value="<%= typeof locals.inv_price !== 'undefined' ? locals.inv_price : '' %>"
        required
        step="0.01"
        min="0"
        placeholder="e.g., 25000.00"
      />
    </div>

    <!-- Mileage Field -->
    <div class="form-field">
      <label for="inv_miles">Mileage (miles):</label>
      <input
        type="number"
        id="inv_miles"
        name="inv_miles"
        value="<%= typeof locals.inv_miles !== 'undefined' ? locals.inv_miles : '' %>"
        required
        min="0"
        placeholder="e.g., 50000"
      />
    </div>

    <!-- Color Field -->
    <div class="form-field">
      <label for="inv_color">Color:</label>
      <input
        type="text"
        id="inv_color"
        name="inv_color"
        value="<%= typeof locals.inv_color !== 'undefined' ? locals.inv_color : '' %>"
        required
        placeholder="e.g., Silver, Red, Blue"
      />
    </div>

    <!-- Form Actions -->
    <div style="display: flex; gap: 1rem; justify-content: center;">
      <button type="submit" class="btn-submit">Add Vehicle</button>
      <a href="/inv" class="btn-cancel">Cancel</a>
    </div>
  </form>
</div>
